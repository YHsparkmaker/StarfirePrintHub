# ── 服务器 ──
HOST=0.0.0.0
PORT=8000
DEBUG=false

# ── 数据库 ──
DATABASE_URL=sqlite+aiosqlite:///./starfire.db

# ── 文件存储 ──
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=20

# ── AI 摘要 ──
AI_ENABLED=false
OPENAI_API_KEY=sk-your-key-here
OPENAI_BASE_URL=https://api.openai.com/v1
AI_MODEL=gpt-4o-mini

# ── 边缘节点 ──
POLL_TIMEOUT_SECONDS=30
JOB_MAX_RETRIES=3
