# ── 服务器 ──
HOST=0.0.0.0
PORT=8000
DEBUG=false

# ── 数据库 ──
DATABASE_URL=sqlite+aiosqlite:///./starfire.db

# ── 文件存储 ──
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=20

# ── AI 摘要 ──
AI_ENABLED=false
OPENAI_API_KEY=sk-your-key-here
OPENAI_BASE_URL=https://api.openai.com/v1
AI_MODEL=gpt-4o-mini

# ── 边缘节点 ──
POLL_TIMEOUT_SECONDS=30
JOB_MAX_RETRIES=3

# ── 微信 JS-SDK (公众号配置, 用于微信内选择聊天文件打印) ──
# 配置步骤: https://developers.weixin.qq.com/doc/offiaccount/OA_Web_Apps/JS-SDK.html
WECHAT_APP_ID=wx_your_app_id_here
WECHAT_APP_SECRET=your_app_secret_here
