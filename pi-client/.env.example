# ── 云端 API ──
CLOUD_BASE_URL=http://103.24.217.85:8000

# ── 节点标识 ──
NODE_ID=pi-3f-a01
NODE_NAME=3楼A区打印机

# ── 打印机队列名 (CUPS 中显示的打印机名称) ──
PRINTER_NAME=Fuji_Xerox_SC2020

# ── 轮询间隔 (秒) ──
POLL_INTERVAL_SECONDS=5
POLL_LONG_INTERVAL_SECONDS=30

# ── 心跳间隔 (秒) ──
HEARTBEAT_INTERVAL_SECONDS=30

# ── 下载目录 ──
DOWNLOAD_DIR=/tmp/starfire-jobs

# ── 重试 ──
MAX_RETRIES=3
RETRY_BACKOFF_FACTOR=2.0

# ── 日志级别: DEBUG | INFO | WARNING | ERROR ──
LOG_LEVEL=INFO

# ── 打印完成提示音 ──
ENABLE_SOUND=true
SOUND_VOLUME=0.7

# ── TTS 播报文本 ──
TTS_SUCCESS=打印完成
TTS_FAILURE=打印失败，请检查打印机
